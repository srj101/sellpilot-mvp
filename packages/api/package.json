{
  "name": "@acme/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./meta": {
      "types": "./dist/lib/meta.d.ts",
      "default": "./src/lib/meta.ts"
    },
    "./meta-inbox": {
      "types": "./dist/lib/meta-inbox.d.ts",
      "default": "./src/lib/meta-inbox.ts"
    },
    "./resolve-contact-names": {
      "types": "./dist/lib/resolve-contact-names.d.ts",
      "default": "./src/lib/resolve-contact-names.ts"
    },
    "./openwa": {
      "types": "./dist/lib/openwa.d.ts",
      "default": "./src/lib/openwa.ts"
    },
    "./chromadb": {
      "types": "./dist/lib/chromadb.d.ts",
      "default": "./src/lib/chromadb.ts"
    },
    "./queue": {
      "types": "./dist/lib/queue.d.ts",
      "default": "./src/lib/queue.ts"
    },
    "./s3": {
      "types": "./dist/lib/s3.d.ts",
      "default": "./src/lib/s3.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@acme/auth": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/validators": "workspace:*",
    "@aws-sdk/client-s3": "^3.1094.0",
    "@aws-sdk/s3-request-presigner": "^3.1094.0",
    "@trpc/server": "catalog:",
    "bullmq": "^5.79.3",
    "chromadb": "^3.5.0",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
