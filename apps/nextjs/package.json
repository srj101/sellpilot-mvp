    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "bullmq": "^5.79.3",
    "chromadb": "^3.5.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.469.0",
    "next": "^16.0.9",
