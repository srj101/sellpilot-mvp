# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_URL=""

# -----------------------------------------------------------------------------
# Authentication (Better-Auth)
# -----------------------------------------------------------------------------
# Generate a secret with `openssl rand -hex 32`
AUTH_SECRET=''

# The production URL of your app.
# Set this if you have a custom domain, otherwise Vercel will set it.
VERCEL_PROJECT_PRODUCTION_URL=""

# The base URL of your app.
# Defaults to VERCEL_PROJECT_PRODUCTION_URL, or http://localhost:3000
BETTER_AUTH_URL=""

# -----------------------------------------------------------------------------
# Google OAuth Provider
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Meta (Facebook, Instagram, WhatsApp)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""

# Optional: Override the default callback URLs for Meta integrations.
# Default for pages/instagram: [host]/api/meta/callback
# Default for whatsapp: [host]/dashboard/integrations
META_CHANNEL_REDIRECT_URI=""
WHATSAPP_REDIRECT_URI=""

# The Graph API version to use. Defaults to v25.0
FACEBOOK_GRAPH_VERSION=""

# -----------------------------------------------------------------------------
# Public (client-side) variables
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FACEBOOK_APP_ID=""
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=""
NEXT_PUBLIC_WHATSAPP_REDIRECT_URI=""