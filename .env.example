# ==========================================
# Database
# ==========================================
POSTGRES_URL="postgresql://username:password@host:5432/database?sslmode=require"

# ==========================================
# Authentication
# ==========================================
AUTH_SECRET="your-auth-secret"

BETTER_AUTH_URL="http://localhost:3000"
VERCEL_PROJECT_PRODUCTION_URL="https://your-domain.com"

# ==========================================
# Google OAuth
# ==========================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==========================================
# Meta / Facebook
# ==========================================
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

META_APP_SECRET="your-meta-app-secret"
META_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"
NEXT_PUBLIC_WHATSAPP_CONFIG_ID="your-whatsapp-config-id"

META_CHANNEL_REDIRECT_URI="http://localhost:3000/api/meta/callback"
WHATSAPP_REDIRECT_URI="http://localhost:3000/dashboard/integrations"
NEXT_PUBLIC_WHATSAPP_REDIRECT_URI="http://localhost:3000/dashboard/integrations"

FACEBOOK_GRAPH_VERSION="v25.0"

# ==========================================
# Cloudflare
# ==========================================
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# ==========================================
# Redis
# ==========================================
REDIS_URL="redis://localhost:6379"

# ==========================================
# OpenWA
# ==========================================
OPENWA_URL="http://localhost:2785"
OPENWA_API_KEY="your-openwa-api-key"

# ==========================================
# AI
# ==========================================
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"