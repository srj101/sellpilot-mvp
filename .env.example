# ==========================================
# Database
# ==========================================
POSTGRES_URL="postgresql://username:password@host:5432/database?sslmode=require"

# ==========================================
# Authentication
# ==========================================
AUTH_SECRET="your-auth-secret"

BETTER_AUTH_URL="http://localhost:3000"
VERCEL_PROJECT_PRODUCTION_URL="https://your-domain.com"

# ==========================================
# Google OAuth
# ==========================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==========================================
# Meta / Facebook
# ==========================================
FACEBOOK_APP_ID="your-facebook-app-id"
# Also used to verify incoming webhook signatures (X-Hub-Signature-256) —
# Meta signs webhooks with the same App Secret used for OAuth/Graph API calls.
FACEBOOK_APP_SECRET="your-facebook-app-secret"

META_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"
# Facebook Login for Business Configuration ID (Meta dashboard > Facebook Login for Business > Configurations)
NEXT_PUBLIC_FACEBOOK_CONFIG_ID="your-facebook-login-config-id"
NEXT_PUBLIC_WHATSAPP_CONFIG_ID="your-whatsapp-config-id"

META_CHANNEL_REDIRECT_URI="http://localhost:3000/api/meta/callback"
WHATSAPP_REDIRECT_URI="http://localhost:3000/dashboard/integrations"
NEXT_PUBLIC_WHATSAPP_REDIRECT_URI="http://localhost:3000/dashboard/integrations"

FACEBOOK_GRAPH_VERSION="v25.0"

# ==========================================
# Cloudflare
# ==========================================
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# ==========================================
# Queue Configuration
# ==========================================
# Queue provider: "memory" (dev), "redis" (production), "sqs" (AWS)
QUEUE_PROVIDER="memory"

# Redis Configuration (for QUEUE_PROVIDER=redis)
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_TLS="false"

# AWS SQS Configuration (for QUEUE_PROVIDER=sqs)
AWS_REGION="us-east-1"
SQS_QUEUE_URL_PREFIX="https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/sellpilot"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# For LocalStack (local AWS emulation)
AWS_ENDPOINT_URL="http://localhost:4566"

# ==========================================
# OpenWA (Unofficial WhatsApp API)
# ==========================================
OPENWA_URL="http://localhost:2785"
OPENWA_API_KEY="your-openwa-api-key"

# ==========================================
# AI Configuration
# ==========================================
OPENAI_API_KEY="your-openai-api-key"
# For OpenRouter, Azure, or other OpenAI-compatible APIs:
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# Model to use (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# ==========================================
# Worker Configuration
# ==========================================
# Rate limiting (messages per hour per account)
RATE_LIMIT_PER_HOUR="200"

# AI timeout in milliseconds (30 seconds default)
AI_TIMEOUT_MS="30000"

# Fallback message when AI is unavailable
AI_FALLBACK_MESSAGE="Thanks for your message! We'll get back to you shortly."

# Worker health check port (for Docker health checks)
WORKER_HEALTH_PORT="3001"

# ==========================================
# ChromaDB (Vector Database)
# ==========================================
CHROMA_URL="http://localhost:8000"
